{
    "manifest_version": 3,
    "name": "Ai-page-summarizer",
    "version": "1.0",
    "description": "A Chrome extension that summarizes web pages using AI.",
    "permissions": [
        "contextMenus",
        "storage",
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
     "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}